{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "rootDir": ".",
    "target": "esnext",
    "sourceMap": true,
    "declaration": true,
    "module": "preserve",
    "skipLibCheck": true,
    "importHelpers": true,
    "declarationMap": true,
    "skipDefaultLibCheck": true,
    "moduleResolution": "bundler",
    "typeRoots": ["node_modules/@types"],
    "paths": {
      "@core": ["./packages/core/src/index.ts"],
      "@core/plugins/*": ["./packages/core/src/plugins/*"],
      "@models": ["./packages/models/src/index.ts"],
      "@react": ["./packages/react/src/index.ts"],
      "@styles": ["./packages/styles/*"]
    }
  }
}
